#!/bin/sh

# This script is to open videos with a-shell

clear
# Show numbered video_dir
echo "===== VLC ====="
video_dir="/private/var/mobile/Library/Mobile Documents/com~apple~CloudDocs/Downloads/Videos/linux"
videos=$(ls "$video_dir")
video_list=$(echo "$videos" | awk '{print NR "\t" $0}')
count=$(echo "$video_list" | wc -l)

echo "===== VIDEOS LIST ====="
echo "$video_list"

# Get User selection
printf "Enter [1..$count]:"
read num
video=$(echo "$video_list" | grep "^$num" ||  echo "[ERROR] Empty value")
echo "[INFO] You have chosen: $video"
file=$(echo "$video" | awk -F '\t' '{print $2}')
# Check if selection is valid
if [ $num -ge 1 ] && [ $num -le $count ]; then 
	open "$video_dir/$file" || echo "[ERROR] Not able to view"
else
	echo "[ERROR] Select from range [1 - $count]!" >&2
fi
