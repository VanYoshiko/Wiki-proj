#!/bin/sh

clear 
echo "======================================"
echo "		-> TODO <-     "
TODO_FILE="/mnt/sharedlocal/home/.local/xdg_data_home/todo.txt"
date="$(date '+%y/%-m/%-d %H:%M')"

function show_help {
	echo "usage: todo [command] [task]"
	echo "Commands:"
	echo "	add [task] 		add task"
	echo "	list				list task"
	echo "	remove [task] 	remove task"
}

add_task() {
	if [ -z "$1" ]; then
		echo "Task cannot be empty"
		exit 1
	fi
	printf "[ ] %s\t$1\n" "$date" >> "$TODO_FILE"
	echo "Added task: $date $1"
}

function list_tasks {
	if [ -s "$TODO_FILE" ]; then
		echo "Your TODO list:"
		cat "$TODO_FILE"
	else 
		echo "No TODO's found"
	fi
}

remove_task() {
	if [ -z "$1" ]; then
		echo "Error: Task to be removed cannot be empty"
		exit 1 
	fi
	if [ ! -f "$TODO_FILE" ]; then
		echo "No tasks found"
		exit 1
	fi
	escaped_task=$(printf %s\n "$1" | sed 's/[]\/$*,^|[]/\\&g')

	sed -i "/^${escaped_task}$/d" "$TODO_FILE"

	echo "Removed task: $1"
}

case "$1" in
	add)
		add_task "$2"
		;;
	list)
		list_tasks
		;;
	remove)
		remove_task "$2"
		;;
	*)
		show_help
		;;
esac

echo "======================================"
