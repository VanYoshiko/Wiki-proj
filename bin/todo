#!/bin/sh


clear 
logger=".local/xdg_config_home/logger_ish"
TODO_FILE="/mnt/sharedlocal/home/.local/xdg_data_home/todo.txt"

asci_colors="/mnt/sharedlocal/home/.local/xdg_state_home/terminal_graphics/.asci_colors"
date="$(date '+%y/%-m/%-d %H:%M')"
source $logger "editing todo"
source $asci_colors
echo -e "${YELLOW}======================================${RESET}"
center 'TODO'

function show_help {
	echo "usage: todo [command] [task]"
	echo "Commands:"
	echo "	add [task] 		add task"
	echo "	list				list task"
	echo "	mark [task] 	mark task"
	echo "	remove [task] 	remove task"
}

add_task() {
	if [ -z "$1" ]; then
		echo -e "${RED}Task cannot be empty${RESET}"
		exit 1
	fi
	printf "[ ] %s\t$1\n" "$date" >> $TODO_FILE
	echo "Added task: $date $1"
}

function list_tasks {
	if [ -s "$TODO_FILE" ]; then
		echo "$?"
		echo "Your TODO list: $(grep "^\[\s\]" .local/xdg_data_home/todo.txt | wc -l)"	
		cat "$TODO_FILE"
	else 
		echo "No TODO's found"
	fi
}

remove_task() {
	if [ -z "$1" ]; then
		echo "${RED}Error: Task to be removed cannot be empty${RESET}"
		exit 1 
	fi
	if [ ! -f "$TODO_FILE" ]; then
		echo "No tasks found"
		exit 1
	fi
	sed -i "/${1}/s/.*\(${1}\).*//g" "$TODO_FILE"
	echo "Removed task: $1"
}

# Mark task as completed!
function mark_task() {
	if [ -z "$1" ]; then
		echo "Error: Task to be removed cannot be empty"
		exit 1 
	fi
	if [ ! -f $TODO_FILE ]; then
		echo "No file or dir..."
	else
		# Search for str and mark w/x		
		sed -i "/${1}/s/\[ \]/\[x\]/" "$TODO_FILE"
		echo "Marked #$1 as done"
	fi
}

case "$1" in
	add)
		add_task "$2"
		;;
	list)
		list_tasks
		;;
	remove)
		remove_task "$2"
		;;
	mark)
		mark_task "$2"
		;;
	*)
		show_help
		;;
esac

echo -e "${YELLOW}======================================${RESET}"
